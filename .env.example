# =============================================================================
# Illuminate MCP Server Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# The server auto-loads .env from the project directory on startup.
# Env vars passed by the MCP client (e.g., Claude Desktop config) take
# precedence — .env only fills in values not already set.
# =============================================================================


# =============================================================================
# Snowflake Connectivity
# =============================================================================
# Required when ENABLE_QUERY_EXECUTION=true or ENABLE_METADATA_INTROSPECTION=true.
# Without these, the server runs in metadata-only mode using the builtin catalog.

# Your Snowflake account identifier. The server automatically strips
# https:// prefixes and .snowflakecomputing.com suffixes if present.
SNOWFLAKE_ACCOUNT=

# Service account credentials for query execution.
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=

# The Snowflake role used for all queries. Must have SELECT access to the
# CDM schemas and INFORMATION_SCHEMA for metadata introspection.
SNOWFLAKE_ROLE=

# The compute warehouse. Size affects query speed and credit consumption.
# Insights scans run ~10 queries with a 30s timeout each.
SNOWFLAKE_WAREHOUSE=

# The Illuminate database containing CDM schemas.
SNOWFLAKE_DATABASE=


# =============================================================================
# Domain and Schema Allowlists
# =============================================================================
# Controls which CDM domains are exposed to the LLM and which schemas are
# allowed in SQL policy validation. These should generally match.
#
# Available domains:
#   CDM_LMS  — Learning Management System (courses, grades, enrollments)
#   CDM_SIS  — Student Information System (students, terms, programs)
#   CDM_TLM  — Teaching & Learning Metadata (telemetry, Caliper events)
#   CDM_ALY  — Analytics (accessibility scores, content scores)
#   CDM_CLB  — Collaborate (virtual classroom sessions, attendance)
#   CDM_MAP  — Cross-system mapping (user/course identity linking)
#   CDM_MEDIA — Video Studio (media content, viewing activity)
#   CDM_META — Metadata (data sources, instance reference)
#
# LEARN is added automatically when ENABLE_LEARN_SCHEMA=true (see below).
# Domains with no tables in Snowflake are auto-excluded during introspection.

ALLOWED_DOMAINS=CDM_LMS,CDM_TLM,CDM_ALY,CDM_SIS,CDM_CLB,CDM_MAP,CDM_MEDIA,CDM_META
ALLOWED_SCHEMAS=CDM_LMS,CDM_TLM,CDM_ALY,CDM_SIS,CDM_CLB,CDM_MAP,CDM_MEDIA,CDM_META

# Optional: restrict to specific tables within allowed schemas.
# Leave empty to allow all tables in the schemas above.
ALLOWED_TABLES=


# =============================================================================
# Runtime Limits
# =============================================================================

# Maximum rows returned per query. The query optimizer infers a smart LIMIT
# (25–5000) based on question intent, but this is the hard ceiling.
MAX_ROWS=1000

# Snowflake statement timeout in seconds. Increase for complex queries.
# Insight diagnostic queries use a separate 30s timeout.
STATEMENT_TIMEOUT_SECONDS=600

# Server-side query confirmation. OFF by default because the MCP client
# (Claude Desktop, etc.) already provides its own tool approval UI.
# Set to true if you want an additional server-side gate before execution.
REQUIRE_QUERY_CONFIRMATION=false

# Session approval mode:
#   approve-all = no server-side confirmation needed (recommended)
#   per-query   = each run_query/display_query call requires approved=true
DEFAULT_SESSION_APPROVAL_MODE=approve-all


# =============================================================================
# Budget Governance
# =============================================================================

# Monthly Snowflake credit limit. The server tracks credit consumption per
# query and emits warnings at the threshold percentages below.
MONTHLY_CREDIT_BUDGET=100

# Comma-separated warning thresholds as percentages of the monthly budget.
# Must be sorted ascending with unique values.
BUDGET_WARNING_THRESHOLDS=70,85,100

# Fallback credit estimation rate (credits per hour of warehouse runtime).
# Used when Snowflake's QUERY_HISTORY doesn't report cloud services credits.
# Set to 0 to disable estimation; set to your warehouse's actual rate for
# more accurate tracking (e.g., 2.0 for an X-Small warehouse).
WAREHOUSE_CREDITS_PER_HOUR=0


# =============================================================================
# Output Shaping
# =============================================================================

# Default output mode for query results:
#   auto  — text summary + table; adds chart hint when visualization intent detected
#   text  — summary text only
#   table — summary + table data
#   viz   — summary + table + chart hint
DEFAULT_OUTPUT_MODE=auto

# Maximum character length for the text summary in query responses.
MAX_TEXT_SUMMARY_LENGTH=1200


# =============================================================================
# Metadata Introspection
# =============================================================================

# When true, loads table/column metadata from Snowflake INFORMATION_SCHEMA
# on first use. This gives accurate schema info for your specific instance.
# When false, uses the builtin catalog (covers standard CDM entities but may
# not match your exact schema if customized).
ENABLE_METADATA_INTROSPECTION=true

# Optional: custom SQL that returns column-level descriptions.
# Must return columns: TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME, DESCRIPTION.
# If empty, column descriptions come from Snowflake COMMENT metadata or
# the builtin catalog defaults.
METADATA_DICTIONARY_QUERY=


# =============================================================================
# Feature Flags
# =============================================================================

# Allow SQL execution against Snowflake. When false, the server operates in
# metadata-only mode — schema browsing works but queries return "execution disabled".
# The Schema Explorer data preview tab and Insights Feed also require this.
ENABLE_QUERY_EXECUTION=true

# Preflight SQL candidates with EXISTS probes before recommending them.
# Requires ENABLE_QUERY_EXECUTION=true. Adds latency but improves recommendation
# accuracy by verifying candidates return data.
ENABLE_PLANNER_PROBES=true

# Timeout for each planner probe query (seconds).
PLANNER_PROBE_TIMEOUT_SECONDS=8

# Maximum number of candidates to probe per plan_query call.
PLANNER_MAX_PROBES=2

# Persist planner feedback (success/failure rates, execution times) across
# server restarts. When false, feedback resets each session.
ENABLE_PERSISTENT_FEEDBACK=true

# File path for persistent feedback data (relative to working directory).
FEEDBACK_STORE_PATH=.planner_feedback.json


# =============================================================================
# LEARN Schema (Blackboard Open Database Schema)
# =============================================================================
# Premium tier only. Provides access to 191+ raw Blackboard Learn source
# tables for direct queries against the original data model.
# When enabled, LEARN is automatically added to ALLOWED_DOMAINS and
# ALLOWED_SCHEMAS — no need to add it manually above.
ENABLE_LEARN_SCHEMA=true
