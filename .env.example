# =============================================================================
# Illuminate MCP Server Configuration
# Copy this file to .env and fill in your values.
# The server auto-loads .env from the project directory on startup.
# =============================================================================

# Snowflake connectivity
# Required when ENABLE_QUERY_EXECUTION=true or ENABLE_METADATA_INTROSPECTION=true
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=

# Domain and schema allowlists
# Available domains: CDM_LMS, CDM_SIS, CDM_TLM, CDM_ALY, CDM_CLB, CDM_MAP, CDM_MEDIA, CDM_META
# LEARN is added automatically when ENABLE_LEARN_SCHEMA=true (see below)
# Domains with no tables in Snowflake are auto-excluded during introspection.
ALLOWED_DOMAINS=CDM_LMS,CDM_TLM,CDM_ALY
ALLOWED_SCHEMAS=CDM_LMS,CDM_TLM,CDM_ALY
# Optional table-level allowlist (empty = all tables in allowed schemas)
ALLOWED_TABLES=

# Runtime limits
MAX_ROWS=1000
STATEMENT_TIMEOUT_SECONDS=120
# Query confirmation is OFF by default — the MCP client provides its own tool approval UI.
# Set to true if you want an additional server-side confirmation step.
REQUIRE_QUERY_CONFIRMATION=false
# approve-all = skip server-side confirmation; per-query = require approved=true per call
DEFAULT_SESSION_APPROVAL_MODE=approve-all

# Budget governance
MONTHLY_CREDIT_BUDGET=100
BUDGET_WARNING_THRESHOLDS=70,85,100
# Optional: set to your warehouse credit-per-hour rate for cost estimation
# when Snowflake query history credit field is not populated
WAREHOUSE_CREDITS_PER_HOUR=0

# Output shaping
# auto = text + table + chart hint when visualization intent detected
# text = summary only; table = summary + table; viz = summary + table + chart hint
DEFAULT_OUTPUT_MODE=auto
MAX_TEXT_SUMMARY_LENGTH=1200

# Metadata introspection (optional)
# When true, loads table/column metadata from Snowflake INFORMATION_SCHEMA
# When false, uses builtin metadata catalog (no Snowflake connection needed)
ENABLE_METADATA_INTROSPECTION=false
# Optional: custom SQL returning TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME, DESCRIPTION
METADATA_DICTIONARY_QUERY=

# Feature flags
ENABLE_QUERY_EXECUTION=false
ENABLE_PLANNER_PROBES=false
PLANNER_PROBE_TIMEOUT_SECONDS=8
PLANNER_MAX_PROBES=2

# Planner feedback persistence (optional)
# When true, execution success/failure data persists across server restarts
ENABLE_PERSISTENT_FEEDBACK=false
FEEDBACK_STORE_PATH=.planner_feedback.json

# LEARN schema (Blackboard Open Database Schema)
# Premium tier only. When enabled, LEARN is automatically added to
# ALLOWED_DOMAINS and ALLOWED_SCHEMAS.
ENABLE_LEARN_SCHEMA=false
